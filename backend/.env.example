# ──────────────────────────────────────
# Database
# ──────────────────────────────────────
DATABASE_URL="postgresql://userbot:userbot_secret_2024@localhost:5432/userbot_db"

# ──────────────────────────────────────
# Redis (BullMQ)
# ──────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ──────────────────────────────────────
# Telegram Bot (for Web App + Media Storage)
# ──────────────────────────────────────
BOT_TOKEN="your_bot_token_here"
MEDIA_CHANNEL_ID="-100xxxxxxxxxx"

# ──────────────────────────────────────
# Telegram MTProto (for Userbots)
# ──────────────────────────────────────
TELEGRAM_API_ID="your_api_id"
TELEGRAM_API_HASH="your_api_hash"

# ──────────────────────────────────────
# Security
# ──────────────────────────────────────
ENCRYPTION_MASTER_KEY="generate-a-64-char-hex-key-here"
WHITELISTED_USER_IDS="123456789,987654321"

# ──────────────────────────────────────
# Server
# ──────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN="*"

# ──────────────────────────────────────
# LLM Integration (Phase 2)
# ──────────────────────────────────────
GROQ_API_KEY="your_groq_api_key_here"
